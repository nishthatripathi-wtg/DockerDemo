{
  "uid": "latency-breakdown",
  "title": "Traefik Trace Latency Breakdown",
  "description": "End-to-end request latency: Traefik total vs Java processing vs Database, by route (median/P95). Excludes actuator/health routes and Grafana internal API traffic.\n\nAssumed label names (from Tempo span_metrics):\n- service_name: traefik, demo-backend\n- span_kind: SPAN_KIND_SERVER, SPAN_KIND_CLIENT\n- http_route: set by OTel Java Agent on demo-backend spans; copied from url.path on Traefik spans via OTel Collector transform processor\n- db_system: postgresql\n- NOTE: deployment_environment is NOT available on spanmetrics; the Environment variable is kept for future use.\n\nLatency unit: milliseconds (queries multiply histogram_quantile seconds \u00d7 1000). All panels use unit 'ms'.",
  "tags": [
    "latency",
    "layers",
    "performance",
    "traefik"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "style": "dark",
  "schemaVersion": 39,
  "version": 1,
  "links": [
    {
      "title": "Service Health Dashboard",
      "type": "link",
      "url": "/d/backend-overview/backend-overview",
      "tooltip": "RPS, Errors, JVM, Connections, Status Codes"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "javaService",
        "type": "constant",
        "label": "Java Service",
        "query": "demo-backend",
        "current": {
          "text": "demo-backend",
          "value": "demo-backend"
        },
        "hide": 2
      },
      {
        "name": "routeLabel",
        "type": "constant",
        "label": "Route Label",
        "query": "http_route",
        "current": {
          "text": "http_route",
          "value": "http_route"
        },
        "hide": 2
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(traces_spanmetrics_calls_total, deployment_environment)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      },
      {
        "name": "endpoints",
        "type": "query",
        "label": "Endpoints",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(traces_spanmetrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$javaService\"}, http_route)",
        "regex": "/^(?!\\/(actuator|health|metrics|\\*|public|d|avatar|apis|v2|explore))(?!\\/api\\/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)\\/).*/",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\u23f1\ufe0f Latency by Layer Over Time",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Median Latency by Processing Layer",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_name=\"traefik\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "Total (Traefik)",
          "instant": false,
          "format": "time_series",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$javaService\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "Java Processing",
          "instant": false,
          "format": "time_series",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$javaService\", span_kind=\"SPAN_KIND_CLIENT\", db_system!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "Database",
          "instant": false,
          "format": "time_series",
          "editorMode": "code"
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "Total (Traefik)",
              "operator": "-",
              "right": "Java Processing"
            },
            "alias": "Traefik Overhead",
            "replaceFields": false
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "noValue": "\u2014",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "drawStyle": "line",
            "pointSize": 5,
            "axisSoftMin": 0
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total (Traefik)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9830"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Java Processing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#E02F44"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Database"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#37872D"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Traefik Overhead"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FADE2A"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean"
          ]
        }
      }
    },
