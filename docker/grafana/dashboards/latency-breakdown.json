    {
      "id": 4,
      "type": "row",
      "title": "\ud83d\udccb Latency Breakdown by Route",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "table",
      "title": "Latency Breakdown by Route",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "traces",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (${routeLabel}) (increase(traces_spanmetrics_calls_total{service_name=\"traefik\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__range]))",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        },
        {
          "refId": "med_total",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le, ${routeLabel}) (rate(traces_spanmetrics_latency_bucket{service_name=\"traefik\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        },
        {
          "refId": "p95_total",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.95, sum by (le, ${routeLabel}) (rate(traces_spanmetrics_latency_bucket{service_name=\"traefik\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        },
        {
          "refId": "med_java",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le, ${routeLabel}) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$javaService\", span_kind=\"SPAN_KIND_SERVER\", ${routeLabel}!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        },
        {
          "refId": "med_db",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.5, sum by (le, ${routeLabel}) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$javaService\", span_kind=\"SPAN_KIND_CLIENT\", db_system!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!=\"\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        },
        {
          "refId": "p95_db",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(histogram_quantile(0.95, sum by (le, ${routeLabel}) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$javaService\", span_kind=\"SPAN_KIND_CLIENT\", db_system!=\"\", ${routeLabel}=~\"$endpoints\", ${routeLabel}!~\"^/(actuator|health|metrics).*\", ${routeLabel}!=\"\", ${routeLabel}!~\"/api/(ds|annotations|prometheus|plugins|dashboards|frontend|live|folders|datasources|search|user|org)/.*\", ${routeLabel}!~\"/public/.*|/d/.*|/avatar/.*|/apis/.*|/v2/.*|/explore.*\"}[$__rate_interval])))) * 1000",
          "legendFormat": "",
          "instant": true,
          "format": "table",
          "editorMode": "code"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "http_route"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "Value #med_total",
              "operator": "-",
              "right": "Value #med_java"
            },
            "alias": "Median Traefik Overhead",
            "replaceFields": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true
            },
            "renameByName": {
              "http_route": "Route",
              "Value #traces": "Traces",
              "Value #med_total": "Median Total",
              "Value #p95_total": "P95 Total",
              "Median Traefik Overhead": "Median Traefik",
              "Value #med_java": "Median Java Logic",
              "Value #med_db": "Median DB",
              "Value #p95_db": "P95 DB"
            },
            "indexByName": {
              "http_route": 0,
              "Value #traces": 1,
              "Value #med_total": 2,
              "Value #p95_total": 3,
              "Median Traefik Overhead": 4,
              "Value #med_java": 5,
              "Value #med_db": 6,
              "Value #p95_db": 7
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "noValue": "\u2014"
        },
